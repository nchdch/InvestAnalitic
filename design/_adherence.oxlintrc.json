{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/_internal/**",
              "components/ai/**",
              "components/data/**",
              "components/forms/**",
              "components/navigation/**",
              "ui_kits/app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Golos Text|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Golos Text, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='AIComposer'] > JSXAttribute > JSXIdentifier[name!=/^(?:placeholder|suggestions|onSend|onSuggestion|hint|disabled|className|key|ref|className|style|children)$/]",
        "message": "<AIComposer> doesn't accept that prop. Declared props: placeholder, suggestions, onSend, onSuggestion, hint, disabled, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='AIMessage'] > JSXAttribute > JSXIdentifier[name!=/^(?:role|name|typing|actions|children|className|key|ref|className|style|children)$/]",
        "message": "<AIMessage> doesn't accept that prop. Declared props: role, name, typing, actions, children, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='AIMessage'] > JSXAttribute[name.name='role'] > Literal[value!=/^(?:ai|user)$/]",
        "message": "<AIMessage> role must be one of 'ai' | 'user'."
      },
      {
        "selector": "JSXOpeningElement[name.name='AllocationSegment'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|color|key|ref|className|style|children)$/]",
        "message": "<AllocationSegment> doesn't accept that prop. Declared props: label, value, color."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|src|shape|size|color|className|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: name, src, shape, size, color, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='shape'] > Literal[value!=/^(?:square|circle)$/]",
        "message": "<Avatar> shape must be one of 'square' | 'circle'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Avatar> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|size|dot|icon|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, size, dot, icon, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|accent|positive|negative|warning|ai|outline)$/]",
        "message": "<Badge> tone must be one of 'neutral' | 'accent' | 'positive' | 'negative' | 'warning' | 'ai' | 'outline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Badge> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|block|loading|disabled|leftIcon|rightIcon|as|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, block, loading, disabled, leftIcon, rightIcon, as, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|soft|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'soft' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:button|a)$/]",
        "message": "<Button> as must be one of 'button' | 'a'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|subtitle|actions|elevation|interactive|tightBody|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: title, subtitle, actions, elevation, interactive, tightBody, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='elevation'] > Literal[value!=/^(?:flat|sm|md)$/]",
        "message": "<Card> elevation must be one of 'flat' | 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|variant|label|children|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: size, variant, label, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<IconButton> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:ghost|outlined|solid)$/]",
        "message": "<IconButton> variant must be one of 'ghost' | 'outlined' | 'solid'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|required|size|prefix|suffix|hint|error|numeric|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, required, size, prefix, suffix, hint, error, numeric."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Input> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PnLValue'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|percent|display|size|arrow|badge|showSignWhenZero|className|key|ref|className|style|children)$/]",
        "message": "<PnLValue> doesn't accept that prop. Declared props: value, percent, display, size, arrow, badge, showSignWhenZero, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='PnLValue'] > JSXAttribute[name.name='display'] > Literal[value!=/^(?:money|percent|both)$/]",
        "message": "<PnLValue> display must be one of 'money' | 'percent' | 'both'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PnLValue'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg|xl)$/]",
        "message": "<PnLValue> size must be one of 'sm' | 'md' | 'lg' | 'xl'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SelectOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<SelectOption> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|unit|icon|delta|deltaPercent|caption|size|key|ref|className|style|children)$/]",
        "message": "<StatCard> doesn't accept that prop. Declared props: label, value, unit, icon, delta, deltaPercent, caption, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg|xl)$/]",
        "message": "<StatCard> size must be one of 'sm' | 'md' | 'lg' | 'xl'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|defaultChecked|onChange|label|size|disabled|id|className|key|ref|className|style|children)$/]",
        "message": "<Switch> doesn't accept that prop. Declared props: checked, defaultChecked, onChange, label, size, disabled, id, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:md|lg)$/]",
        "message": "<Switch> size must be one of 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|count|icon|key|ref|className|style|children)$/]",
        "message": "<TabItem> doesn't accept that prop. Declared props: value, label, count, icon."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
