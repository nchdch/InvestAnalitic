FRONTEND_URL=http://10.3.0.47
API_URL=http://10.3.0.47

# dadata.ru — поиск организаций по ИНН
DADATA_API_KEY=1bea115228691c7bf7d40509c9228ab7d6d22985

# Google OAuth (необязательно, если не нужен вход через Google)
